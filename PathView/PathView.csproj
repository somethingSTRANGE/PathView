<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>PathView</RootNamespace>
    <AssemblyName>pathview</AssemblyName>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <InvariantGlobalization>true</InvariantGlobalization>
    <RuntimeIdentifiers>win-x64;win-arm64</RuntimeIdentifiers>
    <Company>Michael Ryan</Company>
    <Product>PathView</Product>
    <Description>Cleaner, human-readable Windows PATH viewer</Description>
    <Copyright>Copyright © 2026 Michael Ryan</Copyright>
    <Version>1.0.0</Version>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="PathView-Tests" />
  </ItemGroup>

</Project>
